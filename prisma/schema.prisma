// Сайт донатов. Платежи только через Stripe.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- Пользователи (стримеры / доноры) и NextAuth ---
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime? @map("email_verified")
  image         String?
  password      String?   // хеш для credentials
  username      String?   @unique @db.VarChar(100)
  balance       Int       @default(0)
  isVerified    Boolean   @default(false) @map("is_verified")
  verifiedAt    DateTime? @map("verified_at")
  isStreamer    Boolean   @default(false) @map("is_streamer")
  streamerVerified Boolean @default(false) @map("streamer_verified")
  streamerVerifiedAt DateTime? @map("streamer_verified_at")
  twitchId      String?   @map("twitch_id") @db.VarChar(100)
  youtubeId     String?   @map("youtube_id") @db.VarChar(100)
  discordId     String?   @map("discord_id") @db.VarChar(100)
  phone         String?   @db.VarChar(30)
  phoneVerified DateTime? @map("phone_verified")
  bio           String?   @db.Text
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  accounts Account[]
  sessions Session[]
  streams  Streamer[]
  settings UserSettings?
  goals                Goal[]
  goalDisplaySettings  GoalDisplaySettings?
  alerts               Alert[]
  withdrawals          Withdrawal[]
  emailVerificationTokens EmailVerificationToken[]
  phoneVerificationCodes  PhoneVerificationCode[]
  streamerVerification StreamerVerification?
  supportMessages       SupportMessage[]
}

model SupportMessage {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  body      String   @db.Text
  role      String   @db.VarChar(20) // user | support
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([userId, createdAt])
}

model Goal {
  id            String    @id @default(cuid())
  userId        String    @map("user_id")
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  title         String    @db.VarChar(255)
  description   String?   @db.Text
  targetAmount  Float     @map("target_amount")
  currentAmount Float     @default(0) @map("current_amount")
  currency      String    @default("RUB") @db.VarChar(10)
  startDate     DateTime  @default(now()) @map("start_date")
  endDate       DateTime? @map("end_date")
  isActive      Boolean   @default(true) @map("is_active")
  isCompleted   Boolean   @default(false) @map("is_completed")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  donations Donation[]

  @@index([userId])
  @@index([isActive, isCompleted])
}

model GoalDisplaySettings {
  id              String   @id @default(cuid())
  userId          String   @unique @map("user_id")
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  position        String   @default("bottom-right") @db.VarChar(20)
  backgroundColor String?  @map("background_color")
  textColor       String?  @map("text_color")
  barColor        String?  @map("bar_color")
  fontFamily      String?  @map("font_family")
  fontSize        Int?     @map("font_size")
  showTitle       Boolean  @default(true) @map("show_title")
  showDescription Boolean @default(true) @map("show_description")
  showEndDate     Boolean  @default(true) @map("show_end_date")
  borderRadius    Int?     @map("border_radius")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@index([userId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}

model EmailVerificationToken {
  id        String    @id @default(cuid())
  token     String    @unique
  userId    String    @map("user_id")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String    // email, password_reset
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  @@index([userId])
  @@index([token])
}

model PhoneVerificationCode {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  phone    String   @db.VarChar(20)
  code     String   @db.VarChar(10)
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([userId, phone])
}

model StreamerVerification {
  id            String    @id @default(cuid())
  userId        String    @unique @map("user_id")
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  fullName      String    @map("full_name") @db.VarChar(255)
  passportNumber String   @map("passport_number") @db.VarChar(255)
  inn           String?   @db.VarChar(20)
  telegram      String?   @db.VarChar(100)
  phone         String?   @db.VarChar(20)
  passportFile  String    @map("passport_file") @db.Text
  selfieFile    String    @map("selfie_file") @db.Text
  additionalFile String?  @map("additional_file") @db.Text
  status        String    @default("pending") @db.VarChar(20) // pending, approved, rejected
  adminComment  String?   @map("admin_comment") @db.Text
  submittedAt   DateTime  @default(now()) @map("submitted_at")
  reviewedAt    DateTime? @map("reviewed_at")
  reviewedBy    String?   @map("reviewed_by")

  @@index([status])
  @@index([submittedAt])
}

model UserSettings {
  id               String   @id @default(cuid())
  userId           String   @unique @map("user_id")
  donationSettings Json?    @map("donation_settings") // minAmount, maxAmount, allowAnonymous, defaultMessage, enabled, etc.
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Streamer {
  id           String   @id @default(cuid())
  slug         String   @unique @db.VarChar(50)
  displayName  String   @db.VarChar(255)
  donateLinkId String?  @unique @map("donate_link_id") @db.VarChar(24)
  userId       String?  @map("user_id")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user     User?      @relation(fields: [userId], references: [id], onDelete: SetNull)
  donations Donation[]
}

model Donation {
  id                    String   @id @default(cuid())
  streamerId            String
  streamId              String?  @db.VarChar(100)
  goalId                String?
  amountRub             Int
  message               String?  @db.Text
  isAnonymous           Boolean  @default(false)
  status                String   @db.VarChar(20) // pending | succeeded | failed | canceled
  stripePaymentIntentId String?  @unique @db.VarChar(255)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  streamer Streamer @relation(fields: [streamerId], references: [id], onDelete: Cascade)
  goal     Goal?    @relation(fields: [goalId], references: [id], onDelete: SetNull)

  @@index([streamerId])
  @@index([goalId])
  @@index([status])
  @@index([stripePaymentIntentId])
  @@map("donations")
}

model Withdrawal {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  amountRub Int      @map("amount_rub")
  status    String   @db.VarChar(20) // pending | completed | failed | canceled
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
}

// --- Аккаунт разработчика / администратора ---
enum AdminRole {
  SUPER_ADMIN
  ADMIN
  MODERATOR
  SUPPORT
  FINANCE
}

model AdminUser {
  id                 String    @id @default(cuid())
  email              String    @unique
  password           String
  name               String?
  role               AdminRole @default(ADMIN)
  permissions        Json      @default("[]")
  mustChangePassword Boolean   @default(false)
  lastLogin          DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  actions       AdminAction[]
  notifications AdminNotification[]
}

model AdminAction {
  id         String   @id @default(cuid())
  adminId    String
  admin      AdminUser @relation(fields: [adminId], references: [id], onDelete: Cascade)
  actionType String   // login, create, update, delete, ban, verify
  targetType String   // user, donation, stream, system
  targetId   String?
  details    Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  @@index([adminId])
  @@index([createdAt])
}

model AdminNotification {
  id        String    @id @default(cuid())
  adminId   String?   @map("admin_id")
  admin     AdminUser? @relation(fields: [adminId], references: [id], onDelete: Cascade)
  title     String
  message   String   @db.Text
  type      String   // info, warning, success, danger
  isRead    Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())

  @@index([adminId])
}

model SystemSettings {
  id          String   @id @default(cuid())
  key         String   @unique
  value       Json
  description String?
  category    String   // general, payment, security, notification
  updatedAt   DateTime @updatedAt
}

model SystemLog {
  id        String   @id @default(cuid())
  level     String   // info, warn, error, debug
  category  String   // auth, payment, api, database, security
  message   String   @db.Text
  details   Json?
  ipAddress String?
  userId    String?
  createdAt DateTime @default(now())

  @@index([level])
  @@index([category])
  @@index([createdAt])
}

// --- Алерты стримера (донаты, подписки, фолловеры и т.д.) ---
enum AlertType {
  DONATION
  SUBSCRIPTION
  FOLLOW
  RAID
  HOST
  BITS
}

model Alert {
  id            String    @id @default(cuid())
  userId        String    @map("user_id")
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  type          AlertType
  enabled       Boolean   @default(true)

  // Визуальные настройки
  animation     String    @default("default")
  duration      Int       @default(5)
  position      String    @default("bottom-right")

  // Звук
  soundEnabled     Boolean   @default(true) @map("sound_enabled")
  soundFile        String?   @map("sound_file")
  soundVolume      Int       @default(70) @map("sound_volume")
  useDefaultSound  Boolean   @default(false) @map("use_default_sound")

  // Фильтры и пауза (для донатов и др.)
  minAmountRub     Int?      @map("min_amount_rub")
  cooldownSeconds  Int?      @map("cooldown_seconds")

  // Визуальные уточнения
  textOutline      String?   @map("text_outline")   // none | thin | bold
  animationSpeed   Float?    @map("animation_speed") // 0.5 | 1 | 1.5

  // Текст
  messageTemplate String? @map("message_template")
  showMessage   Boolean   @default(true) @map("show_message")
  showAmount    Boolean   @default(true) @map("show_amount")
  showName      Boolean   @default(true) @map("show_name")

  // Внешний вид
  backgroundColor String? @map("background_color")
  textColor      String?  @map("text_color")
  fontFamily     String?  @map("font_family")
  fontSize       Int?     @map("font_size")

  // Кастомные изображения (для премиум)
  imageUrl      String?   @map("image_url")
  imagePosition String?   @map("image_position")

  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  @@unique([userId, type])
  @@index([userId])
}
