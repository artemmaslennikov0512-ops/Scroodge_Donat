# App
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Database
DATABASE_URL="postgresql://user:password@localhost:5432/donations"

# Admin (JWT для панели управления). В production обязателен.
JWT_SECRET=your-secret-at-least-32-chars-long
# Куки админа: true только если сайт по HTTPS. По HTTP (localhost/Docker) оставьте пусто или false
# COOKIE_SECURE=true
# Для создания первого админа задайте и запустите: npm run admin:create (или db:seed)
# ADMIN_EMAIL=admin@donatestream.com
# ADMIN_PASSWORD=SuperSecurePassword123!

# NextAuth (вход пользователей / стримеров)
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-nextauth-secret-at-least-32-chars

# Stripe (единственный платёжный провайдер в проекте)
NEXT_PUBLIC_STRIPE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# SMTP (письма: верификация при регистрации, смена пароля, сброс пароля, верификация стримера)
# Без SMTP в dev ссылки выводятся в консоль.
#
# --- Mail.ru (рекомендуется) ---
# Создайте «пароль приложения» в настройках: Почта → Пароль и безопасность → Пароли приложений
# SMTP_HOST=smtp.mail.ru
# SMTP_PORT=465
# SMTP_USER=your-email@mail.ru
# SMTP_PASSWORD=пароль-приложения
# SMTP_FROM="DonateStream" <your-email@mail.ru>
#
# --- Другие провайдеры ---
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=465
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-password
# SMTP_FROM=DonateStream <noreply@donatestream.com>

# Файлы верификации и аватары: локально или Vercel Blob
# Локально / VPS: папка на диске (по умолчанию ./uploads). На VPS укажите абсолютный путь.
# UPLOAD_DIR=./uploads
# Vercel Blob (опционально): если задан — файлы в Blob, иначе в UPLOAD_DIR
# BLOB_READ_WRITE_TOKEN=vercel_blob_...

# Крон: удаление файлов верификации с диска через 24 ч после рассмотрения. Вызов: GET /api/cron/cleanup-verification-files с заголовком Authorization: Bearer <CRON_SECRET>
# CRON_SECRET=your-random-secret

# За прокси (nginx, Vercel): TRUST_PROXY=true — IP для rate limit берётся из X-Forwarded-For. Без этого IP = "unknown".
# TRUST_PROXY=true
